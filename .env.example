# Firebase Configuration for Frontend
# Get these values from Firebase Console: https://console.firebase.google.com/

# Your Firebase Project API Key
VITE_FIREBASE_API_KEY=your_firebase_api_key_here

# Your Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_project.firebaseapp.com

# Your Firebase Project ID
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id

# Your Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_project.appspot.com

# Your Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id

# Your Firebase App ID
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Backend API URL
VITE_API_URL=http://localhost:5000/api
